<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HTMLエディタ</title>
    <style>
        /* --- レイアウト --- */
        body {
            margin: 0;
            display: flex;
            flex-direction: column;
            height: 100vh;
            font-family: "Yu Gothic UI", "Meiryo UI", sans-serif;
            background-color: #2d2d2d;
            overflow: hidden;
        }

        header {
            background-color: #1e1e1e;
            color: #fff;
            padding: 0 20px;
            height: 50px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid #444;
        }

        .header-left { display: flex; align-items: center; gap: 15px; }
        h1 { font-size: 18px; margin: 0; }
        .status-msg { font-size: 12px; color: #aaa; margin-left: 10px; }

        .btn-help {
            background-color: #555;
            color: #fff;
            border: 1px solid #666;
            padding: 3px 8px;
            border-radius: 3px;
            font-size: 11px;
            cursor: pointer;
            margin-left: 10px;
            transition: background-color 0.2s;
        }
        .btn-help:hover { background-color: #777; }

        .header-buttons { display: flex; gap: 10px; }

        /* --- ツールバー --- */
        .toolbar {
            background-color: #f3f3f3;
            padding: 6px 10px;
            border-bottom: 1px solid #ccc;
            display: flex;
            gap: 4px;
            align-items: center;
            flex-wrap: wrap;
            position: relative;
            z-index: 100;
        }

        .toolbar button {
            height: 28px;
            cursor: pointer;
            border: 1px solid transparent; 
            background: transparent;
            border-radius: 2px;
            padding: 0 6px;
            font-size: 12px;
            min-width: 28px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #333;
        }
        
        .toolbar button:hover { background-color: #dceefc; border-color: #a8d2fd; }
        .toolbar button:disabled { color: #aaa; cursor: default; }
        .toolbar .separator { width: 1px; height: 18px; background: #ccc; margin: 0 6px; }

        .toolbar-right { margin-left: auto; display: flex; align-items: center; }

        .toolbar button.btn-toggle-active {
            background-color: #007acc;
            color: #fff;
            border-color: #005f9e;
            font-weight: bold;
        }
        .toolbar button.btn-toggle-active:hover { background-color: #005f9e; color: #fff; }

        /* --- Office風カラーボタン --- */
        .color-btn-wrapper { position: relative; display: inline-block; }
        .office-color-btn {
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            height: 28px; padding: 0 4px !important; gap: 0;
        }
        .office-color-icon { font-weight: bold; font-size: 14px; line-height: 14px; margin-top: 2px; }
        .office-color-bar { width: 18px; height: 4px; margin-top: 2px; background-color: #C00000; }
        .office-bg-icon { font-weight: bold; font-size: 13px; background: #e0e0e0; padding: 0 2px; line-height: 14px; border: 1px solid #999; }
        .btn-arrow { font-size: 8px; margin-left: 3px; color: #555; cursor: pointer; }

        /* --- Office風パレット --- */
        .color-palette-popup {
            display: none; position: absolute; top: 100%; left: 0; z-index: 1000;
            background: #fff; border: 1px solid #a0a0a0; box-shadow: 2px 2px 8px rgba(0,0,0,0.2);
            padding: 8px; width: 202px; 
        }
        .color-palette-popup.show { display: block; }

        .palette-auto-btn {
            display: flex; align-items: center; width: 100%; padding: 4px;
            border: 1px solid transparent; background: #fff; cursor: pointer;
            font-size: 12px; text-align: left; margin-bottom: 6px; box-sizing: border-box;
        }
        .palette-auto-btn:hover { background-color: #fdeeb3; border-color: #f29436; }
        .palette-auto-icon { width: 14px; height: 14px; border: 1px solid #ccc; background: #000; margin-right: 8px; }
        
        .palette-label { font-size: 11px; color: #666; margin: 4px 0 2px 0; font-weight: bold; }
        .palette-grid { display: grid; grid-template-columns: repeat(10, 1fr); gap: 2px; }

        .color-cell { width: 18px; height: 18px; border: 1px solid #d0d0d0; cursor: pointer; box-sizing: border-box; }
        .color-cell:hover {
            border: 1px solid #f29436; background-clip: content-box; 
            transform: scale(1.1); z-index: 1; box-shadow: 0 0 0 1px #fcd5b4 inset; 
        }

        /* --- メインエリア --- */
        .main-container { display: flex; flex: 1; height: calc(100vh - 90px); position: relative; }
        .pane { display: flex; flex-direction: column; height: 100%; min-width: 0; }
        
        #pane-editor { flex: 0 0 25%; width: auto; }
        #pane-preview { flex: 1 1 0; width: auto; }

        #splitter {
            flex: 0 0 12px; width: 12px; background-color: #3c3c3c; cursor: col-resize;
            transition: background-color 0.2s; user-select: none; touch-action: none; position: relative; z-index: 30;
        }
        #splitter::before { content: ""; position: absolute; top: 0; bottom: 0; left: -10px; right: -10px; cursor: col-resize; }
        body.resizing, body.resizing * { cursor: col-resize !important; user-select: none !important; }
        #splitter:hover, #splitter.dragging { background-color: #007acc; }

        .pane-label { background: #333; color: #fff; padding: 5px 10px; font-size: 12px; display: flex; justify-content: space-between; user-select: none; }
        .pane-label span.note { color: #ffeb3b; font-weight: bold; font-size: 11px; }

        textarea#code-input {
            flex: 1; background-color: #1e1e1e; color: #d4d4d4; border: none; padding: 10px;
            font-family: monospace; font-size: 14px; resize: none; outline: none;
            border-right: 1px solid #444; line-height: 1.5; white-space: pre; box-sizing: border-box; width: 100%;
        }
        textarea#code-input.dragover { background-color: #2d3748; border: 2px dashed #007acc; }

        iframe#preview-frame { flex: 1; border: none; background: #fff; width: 100%; }

        .btn-header { color: white; border: none; padding: 8px 16px; border-radius: 4px; font-weight: bold; cursor: pointer; font-size: 13px; }
        .btn-load { background-color: #4caf50; }
        .btn-load:hover { background-color: #43a047; }
        .btn-save { background-color: #007acc; }
        .btn-save:hover { background-color: #005f9e; }
        .btn-overwrite { background-color: #ff9800; }
        .btn-overwrite:hover { background-color: #f57c00; }
        .btn-header:disabled { background-color: #555 !important; color: #888 !important; cursor: not-allowed; }

        /* --- モーダル --- */
        .modal-overlay {
            display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background-color: rgba(0, 0, 0, 0.6); z-index: 2000; justify-content: center; align-items: center;
        }
        .modal-overlay.show { display: flex; }
        .modal-content { background-color: #fff; color: #333; width: 500px; max-width: 90%; padding: 25px; border-radius: 6px; box-shadow: 0 4px 15px rgba(0,0,0,0.3); position: relative; }
        .modal-content h2 { margin-top: 0; font-size: 20px; border-bottom: 2px solid #007acc; padding-bottom: 8px; color: #007acc; }
        .modal-content ul { padding-left: 20px; line-height: 1.6; font-size: 13px; }
        .modal-content li { margin-bottom: 8px; }
        .modal-close-btn { position: absolute; top: 15px; right: 15px; background: none; border: none; font-size: 20px; cursor: pointer; color: #999; }
        .modal-close-btn:hover { color: #333; }
        .modal-ok-btn { display: block; margin: 20px auto 0 auto; background-color: #007acc; color: white; border: none; padding: 8px 24px; border-radius: 4px; font-weight: bold; cursor: pointer; }
        .modal-ok-btn:hover { background-color: #005f9e; }
    </style>
</head>
<body>

    <header>
        <div class="header-left">
            <h1>HTML Editor</h1>
            <span class="status-msg">※保存時、コード内の&lt;title&gt;をファイル名にします</span>
            <button class="btn-help" onclick="toggleHelpModal(true)">使い方</button>
        </div>
        <div class="header-buttons">
            <button class="btn-header btn-load" onclick="loadHTMLFile()">html読込</button>
            <button class="btn-header btn-overwrite" id="btn-overwrite" onclick="overwriteHTML()" disabled>上書保存</button>
            <button class="btn-header btn-save" onclick="saveHTML()">名前を付けて保存</button>
        </div>
    </header>

    <div class="toolbar">
        <button onclick="customUndo()" id="btn-undo" title="元に戻す" disabled>↶</button>
        <button onclick="customRedo()" id="btn-redo" title="やり直す" disabled>↷</button>
        <div class="separator"></div>
        <button onclick="execCmd('bold')" title="太字"><b>B</b></button>
        <button onclick="execCmd('italic')" title="斜体"><i>I</i></button>
        <button onclick="execCmd('underline')" title="下線"><u>U</u></button>
        <div class="separator"></div>
        
        <div class="color-btn-wrapper">
            <button class="office-color-btn" onclick="togglePalette('palette-fore')" title="文字色">
                <span class="office-color-icon" style="color:#000;">A</span>
                <div class="office-color-bar" id="bar-fore" style="background-color:#C00000;"></div>
            </button>
            <span class="btn-arrow" onclick="togglePalette('palette-fore')">▼</span>
            <div id="palette-fore" class="color-palette-popup">
                <button class="palette-auto-btn" onclick="applyColor('foreColor', '#000000', 'bar-fore')">
                    <span class="palette-auto-icon"></span> 自動
                </button>
                <div class="palette-label">テーマの色</div>
                <div class="palette-grid" id="grid-fore-theme"></div>
                <div class="palette-label">標準の色</div>
                <div class="palette-grid" id="grid-fore-std"></div>
            </div>
        </div>

        <div class="color-btn-wrapper">
            <button class="office-color-btn" onclick="togglePalette('palette-back')" title="背景色">
                <span class="office-bg-icon">ab</span>
                <div class="office-color-bar" id="bar-back" style="background-color:#ffff00;"></div>
            </button>
            <span class="btn-arrow" onclick="togglePalette('palette-back')">▼</span>
            <div id="palette-back" class="color-palette-popup">
                <button class="palette-auto-btn" onclick="applyColor('hiliteColor', 'transparent', 'bar-back')">
                    <span class="palette-auto-icon" style="background:#fff; text-align:center; line-height:12px; color:#ccc;">/</span> 色なし
                </button>
                <div class="palette-label">テーマの色</div>
                <div class="palette-grid" id="grid-back-theme"></div>
                <div class="palette-label">標準の色</div>
                <div class="palette-grid" id="grid-back-std"></div>
            </div>
        </div>
        
        <div class="separator"></div>
        <button onclick="tableCmd('insertRow')" title="行追加">行追加</button>
        <button onclick="tableCmd('deleteRow')" title="行削除">行削除</button>
        <button onclick="tableCmd('insertCol')" title="列追加">列追加</button>
        <button onclick="tableCmd('deleteCol')" title="列削除">列削除</button>
        
        <div class="toolbar-right">
            <button onclick="toggleSyncScroll()" id="btn-sync-scroll" title="プレビュークリック時にエディタを自動スクロールする機能のON/OFF">エディタの自動スクロール：OFF</button>
        </div>
    </div>

    <div class="main-container" id="main-container">
        <div class="pane" id="pane-editor">
            <div class="pane-label">
                HTML Source
                <span class="note">↓ ここにファイルをドロップ、またはコードを貼り付け</span>
            </div>
            <textarea id="code-input" spellcheck="false" autocomplete="off" autocorrect="off" autocapitalize="off" placeholder="ここにHTMLファイルをドロップするか、コードを貼り付けてください..."></textarea>
        </div>
        <div id="splitter" title="ドラッグでサイズ変更 / ダブルクリックで25%に縮小"></div>
        <div class="pane" id="pane-preview">
            <div class="pane-label">Preview</div>
            <iframe id="preview-frame"></iframe>
        </div>
    </div>

    <div class="modal-overlay" id="help-modal">
        <div class="modal-content">
            <button class="modal-close-btn" onclick="toggleHelpModal(false)">×</button>
            <h2>HTMLエディタの使い方</h2>
            <ul>
                <li><strong>プレビュー画面での直接編集</strong><br>右側のプレビュー画面を直接クリックして、文字の入力や編集が可能です。</li>
                <li><strong>エディタの自動スクロール</strong><br>プレビュー画面の要素をクリックすると、エディタ画面が該当コード部まで自動スクロールします。右上のボタンでON/OFFを切り替えられます。</li>
                <li><strong>画面サイズの変更</strong><br>境界線をドラッグすると幅を変更できます。ダブルクリックすると初期サイズに戻ります。</li>
                <li><strong>上書き保存とショートカット</strong><br><code>Ctrl + S</code> で上書き保存、<code>Ctrl + Z</code> で元に戻す、<code>Ctrl + Y</code> でやり直しが可能です。</li>
            </ul>
            <button class="modal-ok-btn" onclick="toggleHelpModal(false)">閉じる</button>
        </div>
    </div>

    <script>
        const codeInput = document.getElementById('code-input');
        const previewFrame = document.getElementById('preview-frame');
        const btnUndo = document.getElementById('btn-undo');
        const btnRedo = document.getElementById('btn-redo');
        const btnOverwrite = document.getElementById('btn-overwrite');
        const btnSyncScroll = document.getElementById('btn-sync-scroll');
        const mainContainer = document.getElementById('main-container');
        const paneEditor = document.getElementById('pane-editor');
        const panePreview = document.getElementById('pane-preview');
        const splitter = document.getElementById('splitter');
        const helpModal = document.getElementById('help-modal');
        
        const themeColors = [
            ['#ffffff', '#f2f2f2', '#d9d9d9', '#bfbfbf', '#a6a6a6', '#808080'],
            ['#000000', '#7f7f7f', '#595959', '#3f3f3f', '#262626', '#0d0d0d'],
            ['#1f4e79', '#d9eaf7', '#bdd7ee', '#9dc3e6', '#5b9bd5', '#2e75b6'],
            ['#833c0c', '#fce4d6', '#f8cbad', '#f4b183', '#ed7d31', '#c65911'],
            ['#375623', '#e2f0d9', '#c6e0b4', '#a9d18e', '#70ad47', '#548235'],
            ['#5f497a', '#e4dfec', '#d9d2e9', '#b4a7d6', '#8064a2', '#604a7b'],
            ['#2f75b5', '#ddebf7', '#cfe2f3', '#9fc5e8', '#6fa8dc', '#3d85c6'],
            ['#a64d79', '#eadcf8', '#d9c2e9', '#c27ba0', '#a64d79', '#741b47'],
            ['#bf9000', '#fff2cc', '#ffe599', '#ffd966', '#f1c232', '#bf9000'],
            ['#c00000', '#f4cccc', '#ea9999', '#e06666', '#cc0000', '#990000']
        ];
        const stdColors = ['#c00000', '#ff0000', '#ffc000', '#ffff00', '#92d050', '#00b050', '#00b0f0', '#0070c0', '#002060', '#7030a0'];
        const SYNC_SCROLL_STORAGE_KEY = 'html_editor_sync_scroll';

        let isUpdating = false;
        let undoStack = [];
        let redoStack = [];
        let saveTimeout = null;
        let fileHandle = null; 
        let isSyncScrollEnabled = false; 

        window.onload = function() {
            codeInput.value = "";
            setupSplitter();
            setupDragAndDrop();
            setupShortcuts();
            loadSyncScrollSetting(); 
            updateHistoryButtons();
            updatePreview();

            try {
                buildPalettes('grid-fore-theme', 'grid-fore-std', 'foreColor', 'bar-fore');
                buildPalettes('grid-back-theme', 'grid-back-std', 'hiliteColor', 'bar-back');
            } catch (err) {
                console.error('カラーパレットの初期化に失敗しました。', err);
            }
        };

        function toggleHelpModal(show) {
            helpModal.classList.toggle('show', show);
        }

        function loadSyncScrollSetting() {
            try {
                const savedSetting = localStorage.getItem(SYNC_SCROLL_STORAGE_KEY);
                isSyncScrollEnabled = (savedSetting === 'true');
            } catch (err) {
                isSyncScrollEnabled = false;
            }
            applySyncScrollUI();
        }

        function toggleSyncScroll() {
            isSyncScrollEnabled = !isSyncScrollEnabled;
            try {
                localStorage.setItem(SYNC_SCROLL_STORAGE_KEY, String(isSyncScrollEnabled));
            } catch (err) {
                console.warn(err);
            }
            applySyncScrollUI();
        }

        function applySyncScrollUI() {
            btnSyncScroll.classList.toggle('btn-toggle-active', isSyncScrollEnabled);
            btnSyncScroll.textContent = isSyncScrollEnabled ? 'エディタの自動スクロール：ON' : 'エディタの自動スクロール：OFF';
        }

        /* --- ドラッグリサイズ --- */
        function setupSplitter() {
            let isDragging = false;
            const setPaneSizes = (clientX) => {
                const rect = mainContainer.getBoundingClientRect();
                let editorWidth = clientX - rect.left;
                editorWidth = Math.max(80, Math.min(rect.width - 140, editorWidth));
                paneEditor.style.flex = `0 0 ${editorWidth}px`;
            };

            splitter.addEventListener('mousedown', (e) => {
                if (e.detail >= 2) { paneEditor.style.flex = '0 0 25%'; return; }
                isDragging = true;
                document.body.classList.add('resizing');
                previewFrame.style.pointerEvents = 'none';
            });

            document.addEventListener('mousemove', (e) => { if (isDragging) setPaneSizes(e.clientX); });
            document.addEventListener('mouseup', () => {
                if (!isDragging) return;
                isDragging = false;
                document.body.classList.remove('resizing');
                previewFrame.style.pointerEvents = 'auto';
            });
            splitter.addEventListener('dblclick', () => { paneEditor.style.flex = '0 0 25%'; });
        }

        function setupDragAndDrop() {
            codeInput.addEventListener('dragover', (e) => { e.preventDefault(); codeInput.classList.add('dragover'); });
            codeInput.addEventListener('dragleave', () => codeInput.classList.remove('dragover'));
            codeInput.addEventListener('drop', (e) => {
                e.preventDefault();
                codeInput.classList.remove('dragover');
                const file = e.dataTransfer.files[0];
                if (file && (file.type === "text/html" || file.name.endsWith('.html') || file.name.endsWith('.htm'))) {
                    const reader = new FileReader();
                    reader.onload = (evt) => {
                        pushHistory();
                        codeInput.value = evt.target.result;
                        updatePreview();
                        fileHandle = null;
                        updateOverwriteButton();
                    };
                    reader.readAsText(file, 'UTF-8');
                }
            });
        }

        /* --- ショートカットキー --- */
        const handleKeydown = function(e) {
            const isCtrl = e.ctrlKey || e.metaKey;
            if (isCtrl && e.key.toLowerCase() === 's') { e.preventDefault(); if (fileHandle) overwriteHTML(); else saveHTML(); }
            else if (isCtrl && e.key.toLowerCase() === 'z') { e.preventDefault(); customUndo(); }
            else if (isCtrl && e.key.toLowerCase() === 'y') { e.preventDefault(); customRedo(); }
        };

        function setupShortcuts() {
            window.removeEventListener('keydown', handleKeydown);
            window.addEventListener('keydown', handleKeydown);
            const doc = previewFrame.contentDocument || previewFrame.contentWindow.document;
            if (doc) {
                doc.removeEventListener('keydown', handleKeydown);
                doc.addEventListener('keydown', handleKeydown);
            }
        }

        /* --- 自動スクロール連動 --- */
        function jumpToEditorCode(targetNode) {
            if (!isSyncScrollEnabled || !targetNode || targetNode.nodeType !== 1) return;
            const text = codeInput.value;
            const lines = text.split('\n');
            const tagName = targetNode.tagName.toLowerCase();
            const textContent = targetNode.textContent.trim().substring(0, 10).toLowerCase();
            
            let targetLineIndex = -1;
            for (let i = 0; i < lines.length; i++) {
                const line = lines[i].toLowerCase();
                if (line.includes(`<${tagName}`) && (!textContent || line.includes(textContent))) {
                    targetLineIndex = i;
                    break;
                }
            }
            if (targetLineIndex !== -1) {
                codeInput.scrollTop = Math.max(0, (targetLineIndex - 4) * 21);
            }
        }

        /* --- ファイル入出力 --- */
        async function loadHTMLFile() {
            try {
                const [handle] = await window.showOpenFilePicker({ types: [{ description: 'HTML Files', accept: { 'text/html': ['.html', '.htm'] } }] });
                fileHandle = handle;
                const file = await fileHandle.getFile();
                pushHistory();
                codeInput.value = await file.text();
                updatePreview();
                updateOverwriteButton();
            } catch (err) { if (err.name !== 'AbortError') alert("読み込みに失敗しました。"); }
        }

        async function overwriteHTML() {
            if (!fileHandle) return;
            try {
                const writable = await fileHandle.createWritable();
                await writable.write(codeInput.value);
                await writable.close();
                alert("上書き保存しました。");
            } catch (err) { alert("上書き保存に失敗しました。"); }
        }

        function updateOverwriteButton() { btnOverwrite.disabled = !fileHandle; }

        async function saveHTML() {
            const rawHtml = codeInput.value;
            const match = rawHtml.match(/<title>(.*?)<\/title>/i);
            const safeTitle = (match ? match[1].trim() : "untitled").replace(/[\\/:*?"<>|]/g, "_");
            try {
                fileHandle = await window.showSaveFilePicker({ suggestedName: `${safeTitle}.html`, types: [{ description: 'HTML Files', accept: { 'text/html': ['.html'] } }] });
                const writable = await fileHandle.createWritable();
                await writable.write(rawHtml);
                await writable.close();
                updateOverwriteButton();
            } catch (err) { if (err.name !== 'AbortError') console.error(err); }
        }

        /* --- プレビュー更新＆同期コア --- */
        function updatePreview() {
            const doc = previewFrame.contentDocument || previewFrame.contentWindow.document;
            if (!doc) return;
            
            // スクロール位置の退避
            const scrollX = previewFrame.contentWindow.scrollX || 0;
            const scrollY = previewFrame.contentWindow.scrollY || 0;

            doc.open();
            doc.write(codeInput.value || "<!DOCTYPE html><html><head></head><body></body></html>");
            doc.close();
            doc.designMode = "on";

            // スクロール位置の復元
            previewFrame.contentWindow.scrollTo(scrollX, scrollY);
            
            // ブラウザ標準の装飾動作をCSSスタイル付与に固定化する（最重要）
            try { doc.execCommand('styleWithCSS', false, true); } catch(e){}

            setupIframeListeners(doc);
        }

        function pushHistory() {
            const currentVal = codeInput.value;
            if (undoStack.length > 0 && undoStack[undoStack.length - 1] === currentVal) return;
            undoStack.push(currentVal);
            redoStack = []; 
            updateHistoryButtons();
        }

        function debouncedSave() {
            if (isUpdating) return; // 同期処理中は新しい履歴を作らない
            if (saveTimeout) clearTimeout(saveTimeout);
            saveTimeout = setTimeout(() => { pushHistory(); }, 1000);
        }

        // エディタ側への手入力時のみ発火
        codeInput.addEventListener('input', function() {
            if (!isUpdating) {
                debouncedSave();
                isUpdating = true;
                updatePreview();
                isUpdating = false;
            }
        });

        function setupIframeListeners(doc) {
            const syncToSource = () => {
                if (isUpdating) return;
                isUpdating = true;
                
                // Doctypeを維持しつつ同期
                let docTypeStr = "<!DOCTYPE html>\n";
                codeInput.value = docTypeStr + doc.documentElement.outerHTML;
                
                // プレビュー側で文字が打たれた場合も履歴タイマーを回す
                if (saveTimeout) clearTimeout(saveTimeout);
                saveTimeout = setTimeout(() => { if (undoStack[undoStack.length-1] !== codeInput.value) pushHistory(); }, 1000);
                
                isUpdating = false;
            };

            doc.addEventListener('keyup', (e) => { if(!['Control', 'Shift', 'Alt'].includes(e.key)) syncToSource(); });
            doc.addEventListener('input', syncToSource);
            doc.addEventListener('mouseup', syncToSource);
            doc.addEventListener('click', (e) => jumpToEditorCode(e.target));
            setupShortcuts();
        }

        /* --- 履歴操作の安定化 --- */
        function customUndo() {
            if (undoStack.length === 0) return;
            redoStack.push(codeInput.value);
            const prevVal = undoStack.pop();
            applyState(prevVal);
        }

        function customRedo() {
            if (redoStack.length === 0) return;
            undoStack.push(codeInput.value);
            const nextVal = redoStack.pop();
            applyState(nextVal);
        }

        function applyState(html) {
            isUpdating = true;
            codeInput.value = html;
            updatePreview();
            updateHistoryButtons();
            isUpdating = false;
        }

        function updateHistoryButtons() {
            btnUndo.disabled = (undoStack.length === 0);
            btnRedo.disabled = (redoStack.length === 0);
        }

        /* --- カラーコマンド＆パレット --- */
        function execCmd(command, value = null) {
            pushHistory(); // 操作直前の状態を必ず保存
            const win = previewFrame.contentWindow;
            win.focus();
            win.document.execCommand(command, false, value);
            
            // 変更を明示的にエディタへ通知
            isUpdating = true;
            codeInput.value = "<!DOCTYPE html>\n" + win.document.documentElement.outerHTML;
            isUpdating = false;
            updateHistoryButtons();
        }

        function buildPalettes(themeId, stdId, command, barId) {
            const themeGrid = document.getElementById(themeId);
            const stdGrid = document.getElementById(stdId);
            if (!themeGrid || !stdGrid) return;
            themeGrid.innerHTML = '';
            stdGrid.innerHTML = '';
            for(let row=0; row<6; row++) {
                for(let col=0; col<10; col++) { themeGrid.appendChild(createCell(themeColors[col][row], command, barId)); }
            }
            stdColors.forEach(c => stdGrid.appendChild(createCell(c, command, barId)));
        }

        function createCell(color, command, barId) {
            const div = document.createElement('div');
            div.className = 'color-cell';
            div.style.backgroundColor = color;
            div.title = color;
            div.onmousedown = (e) => { 
                e.preventDefault(); e.stopPropagation();
                applyColor(command, color, barId);
            };
            return div;
        }

        function applyColor(command, color, barId) {
            execCmd(command, color);
            const bar = document.getElementById(barId);
            if (bar) {
                bar.style.backgroundColor = (color === 'transparent') ? 'transparent' : color;
                bar.style.border = (color === 'transparent') ? '1px solid #ccc' : 'none';
            }
            closeAllPalettes();
        }

        function togglePalette(id) {
            const el = document.getElementById(id);
            const isShown = el.classList.contains('show');
            closeAllPalettes();
            if (!isShown) el.classList.add('show');
        }

        function closeAllPalettes() { document.querySelectorAll('.color-palette-popup').forEach(p => p.classList.remove('show')); }
        document.addEventListener('click', e => { if (!e.target.closest('.color-btn-wrapper')) closeAllPalettes(); });

        function replaceTextInElement(element) {
            Array.from(element.childNodes).forEach(node => {
                if (node.nodeType === Node.ELEMENT_NODE) replaceTextInElement(node);
                else if (node.nodeType === Node.TEXT_NODE && node.textContent.trim().length > 0) node.textContent = "入力";
            });
        }

        /* --- テーブル操作 --- */
        function tableCmd(action) {
            const win = previewFrame.contentWindow;
            const selection = win.getSelection();
            if (selection.rangeCount === 0) return;
            let node = selection.getRangeAt(0).startContainer;
            if (node.nodeType === 3) node = node.parentNode;
            let cell = node.closest('td, th');
            let row = node.closest('tr');
            let table = node.closest('table');
            if (!cell || !row || !table) { alert("表のセルを選択してください"); return; }
            
            pushHistory();
            const rowIndex = row.rowIndex;
            const cellIndex = cell.cellIndex;

            if (action === 'insertRow') {
                const newRow = table.insertRow(rowIndex + 1);
                for (let i = 0; i < row.cells.length; i++) {
                    const newCell = row.cells[i].cloneNode(true);
                    replaceTextInElement(newCell);
                    newRow.appendChild(newCell);
                }
            } 
            else if (action === 'deleteRow') table.deleteRow(rowIndex);
            else if (action === 'insertCol') {
                for (let i = 0; i < table.rows.length; i++) {
                    const tr = table.rows[i];
                    const targetCell = tr.cells[cellIndex];
                    if (targetCell) {
                        const newCell = targetCell.cloneNode(true);
                        replaceTextInElement(newCell);
                        tr.insertBefore(newCell, targetCell.nextSibling);
                    }
                }
            }
            else if (action === 'deleteCol') {
                for (let i = 0; i < table.rows.length; i++) {
                    if (table.rows[i].cells.length > cellIndex) table.rows[i].deleteCell(cellIndex);
                }
            }
            
            isUpdating = true;
            codeInput.value = "<!DOCTYPE html>\n" + win.document.documentElement.outerHTML;
            isUpdating = false;
        }
    </script>
